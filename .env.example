# ============================================
# VPN Gateway — Environment Configuration
# ============================================
# Copy this file to .env and adjust for your network.

# --- Network Settings (for macvlan / UPnP) ---
# Physical network interface on the Docker host (e.g. eth0, enp3s0)
NET_INTERFACE=eth0

# Your home LAN subnet and gateway (router IP)
LAN_SUBNET=192.168.1.0/24
LAN_GATEWAY=192.168.1.1

# IP range for macvlan — must be outside your router's DHCP pool
# Use a small range to avoid conflicts
MACVLAN_IP_RANGE=192.168.1.200/29

# Docker host LAN IP (optional — auto-detected if empty)
# Set this if auto-detection fails
DOCKER_HOST_IP=

# --- WireGuard Settings ---
WG_PORT=51820
WG_PEERS=2

# --- Logging ---
LOG_LEVEL=info
TZ=Europe/Moscow

# --- Internal IPs (do not change) ---
WG_SERVER_IP=10.13.13.1
GATEWAY_IP=10.13.13.2
DNS_IP=10.13.13.3
